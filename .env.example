# ═══════════════════════════════════════════════════════════════════════════
# Callia — Variables d'environnement
# ═══════════════════════════════════════════════════════════════════════════

# ─── Backend (jamais exposé au navigateur) ─────────────────────────────────
# Récupérer la clé sur https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Modèle Claude utilisé par l'agent (optionnel)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Port du backend Express
PORT=3001

# Rate limiting (optionnel)
RATE_LIMIT=30
RATE_WINDOW_MS=60000

# ─── Twilio Voice (pour appels réels) ──────────────────────────────────────
# Le numéro Twilio que tu as acheté (format E.164 : +33XXXXXXXXX)
# Si défini, tous les appels arrivant sur ce numéro sont routés vers l'agent démo
DEMO_TWILIO_NUMBER=

# Numéro vers lequel transférer (escalation) en mode démo
DEMO_ESCALATION_PHONE=

# ─── Supabase (production) ─────────────────────────────────────────────────
# Récupérer sur https://supabase.com > Projet > Settings > API
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...

# Service role key (jamais exposé au browser !) — pour que le backend Twilio
# puisse lire la table agents par numéro et sauvegarder les appels
SUPABASE_SERVICE_KEY=eyJhbGc...

# ─── Admin ─────────────────────────────────────────────────────────────────
# Email qui aura accès au panneau Admin
VITE_ADMIN_EMAIL=
